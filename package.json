{
  "name": "n8n-nodes-ffmpeg-wasm",
  "version": "1.3.0",
  "description": "n8n community node for FFmpeg using ffmpeg.wasm - process audio and video files directly in your workflows",
  "keywords": [
    "n8n",
    "n8n-community-node",
    "n8n-node",
    "ffmpeg",
    "ffmpeg-wasm",
    "video",
    "audio",
    "video-editing",
    "video-processing",
    "video-conversion",
    "video-transcoding",
    "media-processing",
    "media-conversion",
    "convert",
    "transcode",
    "media",
    "webassembly",
    "wasm",
    "workflow-automation"
  ],
  "license": "MIT",
  "homepage": "https://github.com/Prakashmaheshwaran/n8n-nodes-ffmpeg-wasm",
  "author": {
    "name": "Prakash Maheshwaran",
    "email": "pmaheshwaran@binghamton.edu"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Prakashmaheshwaran/n8n-nodes-ffmpeg-wasm.git"
  },
  "main": "dist/nodes/index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix",
    "prepublishOnly": "npm run build",
    "test": "jest"
  },
  "files": [
    "dist",
    "logo.png"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/FFmpegWasmApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/FFmpegWasm/FFmpegWasm.node.js"
    ]
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@typescript-eslint/parser": "^5.45.0",
    "eslint-plugin-n8n-nodes-base": "^1.11.0",
    "gulp": "^4.0.2",
    "gulp-svgmin": "^4.1.0",
    "n8n-workflow": "^1.0.0",
    "prettier": "^2.7.1",
    "ts-jest": "^29.0.3",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@ffmpeg/ffmpeg": "0.11.6",
    "@ffmpeg/core": "0.11.0"
  },
  "bundledDependencies": [
    "@ffmpeg/ffmpeg"
  ],
  "peerDependencies": {
    "n8n-workflow": ">=1.0.0"
  }
}
